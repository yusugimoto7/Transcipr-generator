# Anthropic API key — used server-side only (never exposed to the browser).
# Get one at https://console.anthropic.com
# Keep this set even when using OpenAI: it's the automatic fallback if an
# OpenAI call fails, so the app never breaks.
ANTHROPIC_API_KEY=

# OpenAI (optional) — switch topics + scripts to OpenAI models to cut cost.
# - Set USE_OPENAI=true to turn it on (leave unset/blank to stay on Claude).
# - OPENAI_API_KEY from https://platform.openai.com
# - Model IDs are overridable; defaults are the intended cheap-search /
#   premium-script split. Confirm the exact IDs in your OpenAI dashboard.
USE_OPENAI=
OPENAI_API_KEY=
OPENAI_TOPICS_MODEL=gpt-4o-mini-search-preview
OPENAI_SCRIPT_MODEL=gpt-5.4
OPENAI_ARTICLE_MODEL=gpt-5.4-mini

# WordPress (optional) — enables the "Generate blog article" + "Publish draft"
# feature that posts a Farsi SEO article to your site's Blog as a DRAFT.
# WP_APP_PASSWORD is a WordPress *Application Password* (WP Admin -> Users ->
# your profile -> Application Passwords), NOT your login password.
WP_BASE_URL=https://sugimotovisa.com
WP_USER=
WP_APP_PASSWORD=

# Google Sheet (optional) — permanent, cross-device "seen" memory, a history log
# of every topic shown, AND the Library of every generated script + article (so
# approved content is reusable from any device). If unset, the app keeps the
# Library in per-device browser storage instead. Setup steps are in
# google-apps-script.gs (re-deploy the web app after updating it for Library).
SHEET_WEBHOOK_URL=
SHEET_SECRET=

# Telegram (optional) — enables the "Send to Telegram" button in the script view.
# 1. Create a bot with @BotFather in Telegram -> it gives you the token below.
# 2. Add the bot as an admin to your channel.
# 3. TELEGRAM_CHANNEL_ID is your channel's @username (e.g. @sugimotovisa) or its
#    numeric id (e.g. -1001234567890).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
