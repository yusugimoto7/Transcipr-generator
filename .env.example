# Anthropic API key — used server-side only (never exposed to the browser).
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Telegram (optional) — enables the "Send to Telegram" button in the script view.
# 1. Create a bot with @BotFather in Telegram -> it gives you the token below.
# 2. Add the bot as an admin to your channel.
# 3. TELEGRAM_CHANNEL_ID is your channel's @username (e.g. @sugimotovisa) or its
#    numeric id (e.g. -1001234567890).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
