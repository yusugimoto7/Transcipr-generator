# --- Required ---
# Anthropic API key (server-side only, never shipped to the browser).
ANTHROPIC_API_KEY=

# Secret used to sign session cookies. Use a long random string in production.
# Generate one with: openssl rand -base64 48
AUTH_SECRET=change-me-to-a-long-random-string

# --- Optional ---
# Claude model used for extraction/review/drafting. Defaults to a balanced model.
ANTHROPIC_MODEL=claude-sonnet-5

# Where runtime data and uploads are stored (defaults shown).
DATA_DIR=./data
UPLOAD_DIR=./uploads

# --- Representative / firm details (optional) ---
# Used in the RCIC Submission Letter signature. Defaults to Sugimoto Visa Inc.
# Override any of these to reuse the platform for another consultant.
# RCIC_NAME=Yu Hamed Sugimoto Chavoshi
# RCIC_NUMBER=R713046
# FIRM_NAME=Sugimoto Visa Inc.
# FIRM_PHONE=+1-604-781-0482
# FIRM_EMAIL=hamed@sugimotovisa.com
# FIRM_ADDRESS=501 - 3292 Production Way, Burnaby, Greater Vancouver, BC V5A 4R4
# FIRM_OFFICE_PHONE=+1 (604) 415-4792
# FIRM_OFFICE_EMAIL=info@sugimotovisa.com
# FIRM_WEBSITE=www.sugimotovisa.com
